import "console"
rule {{ cve_id }}
{
    meta:
        date = "{{ date }}"
        file = "{{ file_name }}"
    strings:
        $fix_flag = {{ '{' ~ hex_str ~ '}' }}
    condition:
        $fix_flag and console.log("{{ log_msg }}")
}
